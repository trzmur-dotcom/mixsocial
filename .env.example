# ─────────────────────────────────────────────
#  MixSocial — Environment Variables
#  Copy this file to .env for local overrides.
#  On Railway, set these in the Variables tab.
# ─────────────────────────────────────────────

# REQUIRED in production
JWT_SECRET=replace-with-a-long-random-string-min-64-chars

# Set to "production" to enable frontend serving & strict auth validation
NODE_ENV=production

# Port — Railway sets this automatically, leave blank on Railway
# PORT=3001

# Data directory — mount a Railway Volume at /data and set this
DATA_DIR=/data

# CORS allowed origins (comma-separated, no trailing slash)
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically — use it here
ALLOWED_ORIGINS=https://your-app.up.railway.app
